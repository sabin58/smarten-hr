<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- ================= TREE VIEW ================= -->
    <record id="view_external_news_list" model="ir.ui.view">
        <field name="name">external.news.list</field>
        <field name="model">external.news</field>
        <field name="arch" type="xml">
            <list>
                <field name="name" />
                <field name="link" widget="url" />
            </list>
        </field>
    </record>

    <!-- ================= FORM VIEW ================= -->
    <record id="view_external_news_form" model="ir.ui.view">
        <field name="name">external.news.form</field>
        <field name="model">external.news</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name" />
                        <field name="link" />
                        <field name="thumbnail" widget="image" />
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ================= ACTION ================= -->
    <record id="action_external_news" model="ir.actions.act_window">
        <field name="name">External News</field>
        <field name="res_model">external.news</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_external_news_root"
        name="External News" />

    <menuitem id="menu_external_news"
        name="External News"
        parent="website.menu_website_global_configuration"
        action="action_external_news" />

</odoo>